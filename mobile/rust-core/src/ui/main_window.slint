// mobile/rust-core/src/ui/main_window.slint
// Main Window Definition: Reductive Functionalism (B&W Only).
// Architecture: Hybrid (Free P2P + Premium Server Features).
// Update: Integrated MeetingsView (List/Map), Restored is_premium logic (default false).
// Year: 2026 | Slint Version: 1.6+

import { VerticalLayout, HorizontalLayout, Text, Button, TabWidget } from "std-widgets.slint";

// Import Components
export component TagBadge from "components/tag_badge.slint";
export component UserCard from "components/user_card.slint";
export component NavBar from "components/nav_bar.slint";

// UPDATED IMPORT: MeetingsView now handles List/Map toggle internally
export component MeetingsView from "meetings_view.slint";
export component RelationsView from "relations.slint";
export component PingView from "ping.slint";
export component HelpView from "help.slint";
export component SettingsView from "settings.slint";
// EventsView import remains removed for Alpha version

export component MainWindow inherits Window {
    width: 400px;
    height: 800px;
    title: "Spotka";
    
    // State Properties
    in-out property <bool> is_loading: false;
    
    // RESTORED: Controls visibility of Premium features. 
    // In Alpha, this should be set to 'false' by Rust code.
    in-out property <bool> is_premium: false; 
    
    in-out property <string> active_tab: "meetings";
    in-out property <string> error_message: "";
    
    // Callbacks
    callback request_tab_change(string);
    callback request_refresh();
    callback request_premium_upgrade();

    // Global Style: Monochrome
    default-font-family: "Inter", "Roboto", "San Francisco", sans-serif;
    background: #FFFFFF;
    color: #000000;

    VerticalLayout {
        alignment: center;
        padding: 0px;

        // --- TOP BAR: Status & Subscription ---
        Rectangle {
            height: 40px;
            width: 100%;
            background: #F0F0F0;
            border-bottom-width: 1px;
            border-bottom-color: #000000;
            
            HorizontalLayout {
                alignment: left;
                padding: 10px;
                spacing: 10px;
                Text {
                    text: "Spotka v0.1.0-alpha";
                    font-size: 12px;
                    font-weight: bold;
                    vertical-alignment: center;
                }
                
                // PREMIUM INDICATOR (Visible only if is_premium is true)
                if (root.is_premium) {
                    Rectangle {
                        width: 20px;
                        height: 20px;
                        background: #000000;
                        radius: 10px; // Circle for Premium
                        Text {
                            text: "★"; 
                            color: #FFFFFF;
                            font-size: 14px;
                            horizontal-alignment: center;
                            vertical-alignment: center;
                            y: -2px; // Visual adjustment
                        }
                    }
                    Text {
                        text: tr("LABEL_PREMIUM_ACTIVE");
                        font-size: 10px;
                        font-weight: bold;
                        vertical-alignment: center;
                    }
                } else {
                    // Optional: Show nothing or a subtle "Free Mode" indicator
                    // For Alpha, we might leave this empty to keep UI clean
                    // or show a small icon indicating standard mode.
                }
                
                StandardButton {
                    text: tr("ACTION_REFRESH");
                    min-width: 60px;
                    clicked => root.request_refresh();
                }
            }
        }

        // --- MAIN CONTENT AREA ---
        Rectangle {
            width: 100%;
            height: 100%;
            background: #FFFFFF;
            
            if (root.is_loading) {
                VerticalLayout {
                    alignment: center;
                    Text { text: tr("MSG_LOADING_CORE"); font-size: 16px; }
                }
            } else if (root.error_message != "") {
                VerticalLayout {
                    alignment: center;
                    spacing: 10px;
                    Text { 
                        text: root.error_message; 
                        color: #FF0000; 
                        font-weight: bold;
                        wrap: word-wrap;
                        horizontal-alignment: center;
                    }
                    StandardButton {
                        text: tr("ACTION_RETRY");
                        clicked => root.request_refresh();
                    }
                }
            } else {
                // TAB WIDGET FOR NAVIGATION
                TabWidget {
                    current-index <=> root.active_tab_index;
                    
                    // TAB 1: SPOTKANIA (Meetings) - Uses new MeetingsView with Map/List
                    Tab {
                        title: tr("TAB_MEETINGS");
                        MeetingsView {
                            // Pass premium flag down, though currently MeetingsView might not use it heavily
                            // unless we add premium map layers later.
                            is_premium: root.is_premium; 
                        }
                    }

                    // TAB 2: RELACJE (Relations)
                    Tab {
                        title: tr("TAB_RELATIONS");
                        RelationsView {
                            is_premium: root.is_premium;
                        }
                    }

                    // TAB 3: PING
                    Tab {
                        title: tr("TAB_PING");
                        PingView {}
                    }

                    // TAB 4: WYDARZENIA (Events) - HIDDEN IN ALPHA
                    // No tab shown until feature is implemented.

                    // TAB 5: POMOC (?)
                    Tab {
                        title: "?";
                        HelpView {}
                    }

                    // TAB 6: USTAWIENIA
                    Tab {
                        title: tr("TAB_SETTINGS");
                        SettingsView {
                            is_premium: root.is_premium;
                        }
                    }
                }
            }
        }
        
        // Helper property to map string tab names to TabWidget indices
        in-out property <int> active_tab_index: 0;
        
        // Logic to sync string state with index (simplified mapping)
        // In a real app, this would be more robust
        on active_tab changed => {
            if (active_tab == "meetings") { active_tab_index = 0; }
            else if (active_tab == "relations") { active_tab_index = 1; }
            else if (active_tab == "ping") { active_tab_index = 2; }
            else if (active_tab == "help") { active_tab_index = 3; } // Adjusted index due to hidden Events
            else if (active_tab == "settings") { active_tab_index = 4; } // Adjusted index
        }
    }
}
