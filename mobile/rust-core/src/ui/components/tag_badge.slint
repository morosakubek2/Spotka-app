// mobile/rust-core/src/ui/components/tag_badge.slint
// Tag Badge Component: Visual representation of CTS tags.
// Design: Reductive Functionalism (B&W, patterns instead of colors).
// Features: Status patterns, Official Dict bolding, Compact mode, A11y.
// Year: 2026 | Slint Version: 1.6+

import { Rectangle, Text, HorizontalLayout } from "std-widgets.slint";

// --- Enum for Tag Status (mirrors Rust CtsTagStatus) ---
enum TagStatus {
    Positive,
    Negative,
    Mediating,
    Limiting
}

// --- Component: TagBadge ---
export component TagBadge {
    // Inputs
    in property <string> label;       // The word (e.g., "kino") or index if compressed
    in property <TagStatus> status;
    in property <bool> is_compacted;  // If true, show only index/symbol to save space
    in property <bool> is_official;   // True if from official static dictionary (bold text)

    // Dimensions
    width: is_compacted ? 30px : (label.length() * 14px + 20px);
    height: 30px;

    // Accessibility
    accessible-name: `${label} (${status})`;

    Rectangle {
        background: #ffffff;
        border-color: #000000;
        border-width: 1px;
        radius: 4px;
        width: 100%;
        height: 100%;

        // --- Style Logic based on Status (B&W Patterns) ---

        // 1. Positive: Thick solid border
        border-width: status == TagStatus.Positive ? 2px : 1px;

        // 2. Negative: Cross-hatch pattern overlay (simulated with gradient)
        // Creates a diagonal striped effect to indicate exclusion/negative
        if (status == TagStatus.Negative) {
            Rectangle {
                x: 2px; y: 2px; width: parent.width - 4px; height: parent.height - 4px;
                clip: true;
                background: @linear-gradient(45deg, #000000 25%, transparent 25%, transparent 50%, #000000 50%, #000000 75%, transparent 75%);
                background-repeat: repeat;
                background-size: 4px 4px;
                opacity: 0.3; // Light gray effect using transparency
                z-order: 1;
            }
        }

        // 3. Mediating: Dashed border
        // Indicates an additional activity or suggestion
        if (status == TagStatus.Mediating) {
            Rectangle {
                x: 4px; y: 4px; width: parent.width - 8px; height: parent.height - 8px;
                background: transparent;
                border-color: #000000;
                border-width: 1px;
                border-style: dashed;
                radius: 2px;
                z-order: 2;
            }
        }

        // 4. Limiting: Double border (inner rect)
        // Indicates a condition or missing item requirement
        if (status == TagStatus.Limiting) {
            Rectangle {
                x: 3px; y: 3px; width: parent.width - 6px; height: parent.height - 6px;
                background: transparent;
                border-color: #000000;
                border-width: 1px;
                radius: 2px;
                z-order: 2;
            }
        }

        // --- Content ---
        HorizontalLayout {
            alignment: center;
            padding: 4px;
            spacing: 2px;
            z-order: 3; // Ensure text is above patterns

            // Optional Icon for Limiting/Mediating if not compacted
            if (!is_compacted && (status == TagStatus.Limiting || status == TagStatus.Mediating)) {
                Rectangle {
                    width: 12px; height: 12px;
                    background: #000000;
                    visible: status == TagStatus.Limiting;
                    clip: true;
                    // Simplified triangle rendering via clip path would go here
                    // For now, a solid square acts as a placeholder for the warning icon
                }
                Rectangle {
                    width: 12px; height: 12px;
                    background: #000000;
                    visible: status == TagStatus.Mediating;
                    radius: 6px; // Circle/Dot
                }
            }

            Text {
                text: label;
                font-size: is_compacted ? 10px : 14px;
                // Bold text if from official dictionary for quick visual recognition
                font-weight: is_official ? bold : normal; 
                color: #000000;
                vertical-alignment: center;
                horizontal-alignment: center;
                
                // Strikethrough for Negative (redundant with pattern but good for A11y/clarity)
                text-strike-through: status == TagStatus.Negative;
            }
        }
    }
}

// --- Example Usage (Commented out for production) ---
