// mobile/rust-core/src/ui/ping.slint
// PING Module: Physical Pairing (QR/NFC/SMS) & Dictionary Sync.
// Design: Reductive Functionalism (B&W only, geometric patterns).
// Year: 2026 | Slint Version: 1.6+

import { VerticalLayout, HorizontalLayout, Text, Button, TextInput, Rectangle, Timer } from "std-widgets.slint";

// --- Constants ---
// In production, these would be passed from Rust logic
property <duration> qr_refresh_interval: 30s; 
property <duration> sms_timeout: 5min;

// --- Component: Dynamic QR Placeholder ---
// Represents the changing QR code for the Organizer.
// In B&W style: A grid of black/white squares with a central timer indicator.
component QrDisplay {
    in property <string> qr_data; // The payload string
    in property <int> time_left_seconds;
    
    width: 250px;
    height: 250px;
    
    Rectangle {
        background: #ffffff;
        border-color: #000000;
        border-width: 2px;
        width: 100%;
        height: 100%;
        
        // Simulated QR Pattern (Geometric noise)
        // In real app, this renders the actual QR code generated by Rust
        GridPattern {
            x: 10px; y: 10px; width: 230px; height: 230px;
            cell-size: 10px;
            // Logic to color cells based on qr_data hash would be in Rust binding
        }

        // Central Timer Indicator (Circle shrinking or digits)
        Rectangle {
            x: 75px; y: 75px; width: 100px; height: 100px;
            background: #ffffff;
            border-color: #000000;
            border-width: 1px;
            radius: 50px;
            
            Text {
                text: `${time_left_seconds}s`;
                font-size: 24px;
                font-weight: bold;
                color: #000000;
                horizontal-alignment: center;
                vertical-alignment: center;
                width: 100%;
                height: 100%;
            }
        }
        
        // Corner markers for scanner alignment
        Rectangle { x: 10px; y: 10px; width: 20px; height: 20px; background: #000000; }
        Rectangle { x: 220px; y: 10px; width: 20px; height: 20px; background: #000000; }
        Rectangle { x: 10px; y: 220px; width: 20px; height: 20px; background: #000000; }
        Rectangle { x: 220px; y: 220px; width: 20px; height: 20px; background: #000000; }
    }
}

// --- Component: Scanner Viewfinder ---
// Visual guide for the camera overlay.
component ScannerView {
    width: 250px;
    height: 250px;
    
    Rectangle {
        background: transparent;
        border-color: #000000;
        border-width: 2px;
        width: 100%;
        height: 100%;
        
        // Dashed line effect using pattern or multiple rects
        // Simplified here as solid border for B&W clarity
        
        Text {
            text: tr("KEY_PING_ALIGN_QR");
            color: #000000;
            horizontal-alignment: center;
            y: 260px;
            width: 100%;
        }
        
        // NFC Icon Placeholder (if NFC is detected)
        Rectangle {
            visible: root.nfc_available;
            x: 100px; y: -40px; width: 50px; height: 50px;
            background: #000000; // Solid black icon
            // Shape would be 'N' waves in real implementation
        }
    }
}

// --- Main Ping Window ---
export component PingWindow inherits Window {
    width: 400px;
    height: 700px;
    title: tr("KEY_PING_TITLE");

    // State
    in-out property <bool> is_organizer_mode: true;
    in-out property <bool> is_scanning: false;
    in-out property <int> timer_seconds: 30;
    in-out property <string> status_message: "";
    in-out property <bool> nfc_available: false;
    in-out property <bool> dict_sync_pending: false;

    // Timer for QR refresh
    Timer {
        interval: 1s;
        running: is_organizer_mode && !is_scanning;
        triggered => {
            if (timer_seconds > 0) {
                timer_seconds -= 1;
            } else {
                // Refresh QR data logic in Rust
                timer_seconds = 30; 
                root.status_message = tr("KEY_PING_QR_REFRESHED");
            }
        }
    }

    VerticalLayout {
        alignment: center;
        padding: 20px;
        spacing: 20px;

        // Header: Mode Switcher
        HorizontalLayout {
            spacing: 10px;
            
            Button {
                text: tr("KEY_PING_MODE_ORGANIZER");
                enabled: !is_organizer_mode;
                clicked => {
                    is_organizer_mode = true;
                    is_scanning = false;
                    root.status_message = tr("KEY_PING_WAITING_FOR_SCAN");
                }
            }
            
            Button {
                text: tr("KEY_PING_MODE_PARTICIPANT");
                enabled: is_organizer_mode;
                clicked => {
                    is_organizer_mode = false;
                    is_scanning = true;
                    root.status_message = tr("KEY_PING_SCANNING");
                }
            }
        }

        // Content Area
        if (is_organizer_mode) {
            // --- ORGANIZER VIEW ---
            VerticalLayout {
                alignment: center;
                spacing: 15px;

                Text {
                    text: tr("KEY_PING_SHOW_TO_FRIEND");
                    font-weight: bold;
                    font-size: 18px;
                }

                QrDisplay {
                    qr_data: "mock_payload_hash"; // Bound to Rust
                    time_left_seconds: timer_seconds;
                }

                Text {
                    text: tr("KEY_PING_EXPIRES_IN");
                    font-size: 14px;
                }

                // SMS Fallback Option
                Button {
                    text: tr("KEY_PING_SMS_FALLBACK");
                    // Visible if QR scan fails or user prefers manual entry
                    clicked => {
                        // Trigger SMS send logic in Rust
                        root.status_message = tr("KEY_PING_SMS_SENT");
                    }
                }
                
                // Dictionary Sync Status
                if (dict_sync_pending) {
                    Text {
                        text: tr("KEY_PING_SYNCING_DICT");
                        font-style: italic;
                        color: #555555;
                    }
                }
            }
        } else {
            // --- PARTICIPANT VIEW ---
            VerticalLayout {
                alignment: center;
                spacing: 15px;

                ScannerView {
                    // In real app, this overlays the camera feed
                }

                Text {
                    text: root.status_message;
                    font-size: 16px;
                    horizontal-alignment: center;
                    wrap: word-wrap;
                }

                // Manual Code Entry (Fallback)
                TextInput {
                    placeholder-text: tr("KEY_PING_ENTER_CODE_MANUAL");
                    horizontal-alignment: center;
                    // Only show if scanning fails
                }

                Button {
                    text: tr("KEY_PING_VERIFY_SMS");
                    clicked => {
                        // Trigger SMS read/verify logic
                        root.status_message = tr("KEY_PING_VERIFYING");
                    }
                }
                
                // NFC Prompt
                if (nfc_available) {
                    Text {
                        text: tr("KEY_PING_NFC_TAP_HINT");
                        font-size: 14px;
                        font-style: italic;
                    }
                }
            }
        }

        // Footer: Info / Help
        Text {
            text: tr("KEY_PING_INFO_PHYSICAL_ONLY");
            font-size: 12px;
            horizontal-alignment: center;
            wrap: word-wrap;
            color: #666666;
        }
    }
}
