.idea/
.vscode/
*.swp
*.swo
*~
.project
.classpath
.settings/
*.sublime-project
*.sublime-workspace
*.iml

# Temporary & Logs
tmp/
temp/
*.log
logs/
*.bak
*.tmp

# ==============================================================================
# RUST SPECIFIC
# ==============================================================================

# Build artifacts
/target/
**/target/
debug/
release/

# Cargo lock (optional: usually committed for binaries, but ignored here for lib flexibility)
# Cargo.lock 

# Rust backup files
*.rs.bk
*.pdb

# Coverage reports
*.gcno
*.gcda
coverage/
lcov.info

# Slint generated files (intermediate)
**/*.slint.rust
**/*.slint.json

# ==============================================================================
# ANDROID SPECIFIC
# ==============================================================================

# Gradle
.gradle/
build/
**/build/
*/build/

# Local configuration
local.properties
keystore.properties
.secrets/

# IntelliJ IDEA
*.iml
.out/

# NDK / C++
.cxx/
.externalNativeBuild/
.ndk-build/

# APKs and AABs (Build outputs)
*.apk
*.aab
*.ap_
*.dex
*.class

# Spotka Specific: Native libs generated by cargo-ndk
# These should be built locally or by CI, not stored in git
mobile/android/app/src/main/jniLibs/*/libspotka_core.so
mobile/android/app/src/main/jniLibs/**/libspotka_core.so

# Test outputs
captures/
test-results/

