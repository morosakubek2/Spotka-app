token.txt

# ==============================================================================
# SPOTKA APPLICATION DATA (USER PRIVACY)
# ==============================================================================

# Local Encrypted Databases (User Data - NEVER COMMIT)
*.db
*.db-shm
*.db-wal
spotka_data.db
spotka_test.db
**/*.sqlite
**/*.sqlite3

# User Custom Dictionaries (Private)
assets/dicts/user_custom.json
assets/dicts/local_cache.json
assets/dicts/session_dict_*.json

# Backup files generated by the app
backups/
*.spotka-backup

# Identity Keys (If exported temporarily)
identity_backup.key
private_key.pem

